SECRET_KEY=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-generated-fernet-key
ENVIRONMENT=development
POSTGRES_DSN=postgresql+psycopg2://smcc:smcc@localhost:5432/smcc
REDIS_URL=redis://localhost:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEV_MODE=true
APP_RATE_LIMIT=120/minute
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=https://social-media-management-api.onrender.com
FRONTEND_BASE_URL=http://localhost:3000

# Render production example:
# ENVIRONMENT=production
# APP_PUBLIC_URL=https://your-netlify-site.netlify.app
# API_PUBLIC_URL=https://your-render-api.onrender.com
# FRONTEND_BASE_URL=https://your-netlify-site.netlify.app

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smcc
S3_REGION=us-east-1
S3_PUBLIC_BASE=http://localhost:9000/smcc

FACEBOOK_CLIENT_ID=replace-with-facebook-client-id
FACEBOOK_CLIENT_SECRET=replace-with-facebook-client-secret
FACEBOOK_REDIRECT_URI=https://social-media-management-api.onrender.com/oauth/facebook/callback
FACEBOOK_OAUTH_SCOPES=pages_manage_posts,pages_read_engagement,pages_show_list

LINKEDIN_CLIENT_ID=replace-with-linkedin-client-id
LINKEDIN_CLIENT_SECRET=replace-with-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://social-media-management-api.onrender.com/oauth/linkedin/callback
LINKEDIN_OAUTH_SCOPES=openid profile w_member_social

X_CLIENT_ID=replace-with-x-client-id
X_CLIENT_SECRET=replace-with-x-client-secret
X_REDIRECT_URI=https://social-media-management-api.onrender.com/oauth/x/callback
X_OAUTH_SCOPES=tweet.write users.read offline.access

AYRSHARE_API_KEY=
